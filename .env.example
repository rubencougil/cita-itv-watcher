APPLUS_URL=https://aibs.appluscorp.com/?MenuActivo=mrNuevaReserva
APPLUS_LANGUAGE=es
# Optional: preselect a specific ITV center when the site requires it.
# APPLUS_UID_CENTRO=B09

APPLUS_LICENSE_PLATE=XXXXYYY
APPLUS_CONTACT_EMAIL=you@example.com
APPLUS_CONTACT_PHONE=600000000

# ISO date. The watcher alerts for available slots on or after this date.
APPLUS_MIN_DATE=2026-06-17

TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=123456789
SEND_STARTUP_NOTIFICATION=true
HEARTBEAT_INTERVAL_MINUTES=60

POLL_INTERVAL_MS=300000
HEADLESS=true
RUN_ONCE=false
STATE_FILE=.itv-watcher-state.json
